rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper to get request data
    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Mandatory Size Enforcements & 2. Validation Blueprints
    function isValidProfile(data) {
      return data.keys().hasAll(['id', 'updated_at']) &&
             data.id is string && data.id.size() <= 128 &&
             data.updated_at is string &&
             (!('email' in data) || data.email == null || (data.email is string && data.email.size() <= 256)) &&
             (!('display_name' in data) || (data.display_name is string && data.display_name.size() <= 100)) &&
             (!('photo_url' in data) || (data.photo_url is string && data.photo_url.size() <= 1000)) &&
             (!('role' in data) || (data.role is string && data.role.size() <= 20)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 512));
    }

    // Phase 4: Match Blocks
    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isOwner(userId);
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (resource.data.user_id == request.auth.uid || request.auth.token.email == 'midusab@gmail.com');
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid;
      allow update: if isSignedIn() && (
                      (resource.data.user_id == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updated_at'])) ||
                      (request.auth.token.email == 'midusab@gmail.com')
                    );
    }

    match /program_updates/{updateId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.token.email == 'midusab@gmail.com';
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid;
      allow delete, update: if isSignedIn() && request.auth.token.email == 'midusab@gmail.com';
    }

    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update: if isSignedIn() && request.auth.token.email == 'midusab@gmail.com';
    }
  }
}
